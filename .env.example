# ─────────────────────────────────────────────────────────────
#  Project root .env  (read by docker-compose for VPN secrets)
#  Copy to .env and fill in values:   cp .env.example .env
#  This file is gitignored — never commit .env
# ─────────────────────────────────────────────────────────────

# VPNjantit credentials used by the gluetun container.
# Get a free account at https://www.vpnjantit.com
# Then download a Qatar (QA) or UAE (AE) OpenVPN config and
# place it at  vpn/server.ovpn  on the server.
OPENVPN_USER=your_vpnjantit_username
OPENVPN_PASSWORD=your_vpnjantit_password
