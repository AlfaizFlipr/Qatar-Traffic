# ── Server ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development
# Comma separated list of allowed origins for CORS (frontend dev/prod URLs)
CORS_ORIGIN=http://localhost:5173

# ── MongoDB ────────────────────────────────────────────
MONGODB_URI=mongodb+srv://alfaiz:alfaiz123@cluster0.9coh350.mongodb.net/qatar_violations

# ── Telegram (payment relay) ───────────────────────────
# Create a bot via @BotFather to get the token.
TELEGRAM_BOT_TOKEN=8661691199:AAGysGhC5i_4sndJylilvoqD9Y9kDCQ6GEE
# Numeric chat id (user/group) the bot sends submissions to.
# Get it by messaging the bot then calling getUpdates, or use @userinfobot.
TELEGRAM_CHAT_ID=2133988859
# Optional: handle shown inside the message (e.g. @support_qatar)
TELEGRAM_USERNAME=@alfaiz_support_qatar_bot

# ── Violation data provider ────────────────────────────
# "mock"    -> deterministic generated data (no external dependency)
# "http"    -> calls VIOLATION_API_URL (must return the expected shape)
# "scraper" -> Playwright scraper of the MOI portal (Option B). Requires:
#                npm i playwright && npx playwright install chromium
VIOLATION_PROVIDER=scraper
VIOLATION_API_URL=
VIOLATION_API_KEY=

# Scraper provider settings
MOI_URL=https://fees2.moi.gov.qa/moipay/inquiry/violation
# When true, the scraper throws on failure instead of falling back to mock data.
SCRAPER_STRICT=false
# Run Chromium headless (true) or visible (false) during live scrapes.
SCRAPER_HEADLESS=true

# ── User-assisted CAPTCHA flow (Option A) ──────────────
# "simulated" -> backend generates a real CAPTCHA image; passing it returns mock data
#                (works out of the box, great for testing the whole UX).
# "live"      -> Playwright opens the MOI portal, screenshots the real CAPTCHA, and
#                after the user solves it, submits + parses real results.
SCRAPER_MODE=live
# How long a CAPTCHA session stays open before expiring (ms).
CAPTCHA_TTL_MS=180000
# How long scraped/looked-up results are cached per identifier (ms).
CACHE_TTL_MS=600000

# ── OpenVPN (connect before live scraping) ─────────────
# When true the backend launches OpenVPN itself and waits for the tunnel.
# IMPORTANT: start the backend from an Administrator terminal so OpenVPN can
# create the network adapter. Set false to connect manually via the GUI.
VPN_ENABLED=false
OPENVPN_BIN=C:\Program Files\OpenVPN\bin\openvpn.exe
OPENVPN_CONFIG=C:\Users\LENOVO\OpenVPN\config\Alfaiz78040-ae1.vpnjantit-udp-2500.ovpn
# Optional path to a username/password file if your config needs auth-user-pass.
OPENVPN_AUTH=
VPN_TIMEOUT_MS=45000
# Log every OpenVPN line (useful when debugging the connection).
VPN_VERBOSE=false

# ── Live MOI selectors ─────────────────────────────────
# These match the real MOI moipay portal (QID/plate/company tabs).
# The scraper also AUTO-DISCOVERS the field, captcha input and submit button
# inside the captcha's form, so these are just the first guess. Override only
# after confirming the live DOM via: npm run inspect
SEL_PLATE='#plateNo'
SEL_PERSONAL='#qidNo'
SEL_ESTABLISHMENT='#cpyBrnNo'
SEL_CAPTCHA_IMG='img#captchaImgQid, img#captchaImgPlateNum, img#captchaImgCompany, img[src*="captcha" i]'
SEL_CAPTCHA_INPUT='#captchaResponseQid, #captchaResponsePlateNo, #captchaResponseCompany, input[id*="captchaResponse" i]'
SEL_SUBMIT='button.btn-primary, button[type="submit"], input[type="submit"], button[onclick*="search" i]'
SEL_RESULTS='table.table, .results-table, [id*="result" i], [id*="violation" i]'
SEL_RESULT_ROW='table.table tbody tr, table tbody tr'
SEL_NO_RESULTS='.no-results, .no-data, .alert'
SEL_CAPTCHA_ERROR='.captcha-error, .error-message, .alert-danger'
