# Backend production environment — fees2.com
# ─────────────────────────────────────────────────────────────
# Copy this file to backend/.env.production and fill in values
# DO NOT commit .env.production to Git (already in .gitignore)
# ─────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# Allow requests from frontend + admin domains
CORS_ORIGIN=https://fees2.com,https://www.fees2.com,https://admin.fees2.com

# ── MongoDB ─────────────────────────────────────────────────
# Use your MongoDB Atlas connection string (already configured)
MONGODB_URI=mongodb+srv://alfaiz:alfaiz123@cluster0.9coh350.mongodb.net/qatar_violations?retryWrites=true&w=majority

# ── Admin credentials ────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>
ADMIN_TOKEN_SECRET=<CHANGE_ME_LONG_RANDOM_SECRET_64_CHARS>
ADMIN_TOKEN_TTL_MS=43200000

# ── Telegram (payment relay) ─────────────────────────────────
TELEGRAM_BOT_TOKEN=8661691199:AAGysGhC5i_4sndJylilvoqD9Y9kDCQ6GEE
TELEGRAM_CHAT_ID=2133988859
TELEGRAM_USERNAME=@alfaiz_support_qatar_bot

# ── Violation data provider ──────────────────────────────────
VIOLATION_PROVIDER=scraper
MOI_URL=https://fees2.moi.gov.qa/moipay/inquiry/violation
SCRAPER_STRICT=false
SCRAPER_HEADLESS=true
SCRAPER_MODE=live
CAPTCHA_TTL_MS=180000
CACHE_TTL_MS=600000

# ── Playwright proxy (routes scraper through gluetun VPN) ───
# Set automatically by docker-compose via the gluetun service.
# Override here only if you run without docker-compose.
PLAYWRIGHT_PROXY=http://gluetun:8888

# ── OpenVPN — disabled inside Docker (gluetun handles it) ───
VPN_ENABLED=false

# ── VPNjantit credentials for gluetun ───────────────────────
# These are read by docker-compose from the shell environment.
# Run: export OPENVPN_USER=your_vpnjantit_user
#      export OPENVPN_PASSWORD=your_vpnjantit_password
# Or add them to a .env file in the project root (never commit it).
OPENVPN_USER=your_vpnjantit_username
OPENVPN_PASSWORD=your_vpnjantit_password

# ── MOI selectors (defaults — override if DOM changes) ───────
SEL_PLATE='#plateNo'
SEL_PERSONAL='#qidNo'
SEL_ESTABLISHMENT='#cpyBrnNo'
SEL_CAPTCHA_IMG='img#captchaImgQid, img#captchaImgPlateNum, img#captchaImgCompany, img[src*="captcha" i]'
SEL_CAPTCHA_INPUT='#captchaResponseQid, #captchaResponsePlateNo, #captchaResponseCompany, input[id*="captchaResponse" i]'
SEL_SUBMIT='button.btn-primary, button[type="submit"], input[type="submit"], button[onclick*="search" i]'
SEL_RESULTS='table.table, .results-table, [id*="result" i], [id*="violation" i]'
SEL_RESULT_ROW='table.table tbody tr, table tbody tr'
SEL_NO_RESULTS='.no-results, .no-data, .alert'
SEL_CAPTCHA_ERROR='.captcha-error, .error-message, .alert-danger'
