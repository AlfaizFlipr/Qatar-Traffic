{
  "name": "qatar-violations-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Traffic violation inquiry API with MongoDB and Telegram payment relay",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc -p tsconfig.json",
    "postinstall": "npx playwright install chromium",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "seed": "ts-node src/scripts/seed.ts",
    "test:e2e": "ts-node src/scripts/e2e.ts",
    "inspect": "ts-node src/scripts/inspect.ts"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.0",
    "playwright": "^1.61.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.5",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
