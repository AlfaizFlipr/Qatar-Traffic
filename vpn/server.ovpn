client
disable-dco
dev tun

proto tcp-client

remote ae1.vpnjantit.com 1194
remote 109.61.18.102 1194

remote-random
resolv-retry infinite
nobind

persist-tun

auth-user-pass
auth-nocache

cipher AES-128-CBC
data-ciphers AES-128-CBC
data-ciphers-fallback AES-128-CBC
auth SHA1

remote-cert-tls server

redirect-gateway def1
dhcp-option DNS 8.8.8.8
dhcp-option DNS 1.1.1.1

verb 4
connect-retry 5
connect-timeout 20



